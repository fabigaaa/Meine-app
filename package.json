{
  "name": "meine-app",
  "version": "1.0.0",
  "main": "expo-router/entry",
  "scripts": {
    "start": "expo start",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web",
    "electron:dev": "concurrently -k -n \"EXPO,ELECTRON\" -c \"cyan,yellow\" \"expo start --web --port 8081\" \"wait-on http://localhost:8081 && electron electron/main.js\"",
    "electron:build": "expo export --platform web && electron-builder --win --config electron-builder.json",
    "electron:build:mac": "expo export --platform web && electron-builder --mac --config electron-builder.json"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.95.1",
    "@expo/metro-runtime": "~6.1.2",
    "@expo/vector-icons": "^15.0.3",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@react-native-community/datetimepicker": "8.4.4",
    "date-fns": "^4.1.0",
    "expo": "~54.0.33",
    "expo-constants": "~18.0.13",
    "expo-font": "~14.0.11",
    "expo-linking": "~8.0.12",
    "expo-router": "~6.0.23",
    "expo-status-bar": "~3.0.9",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-native": "0.81.5",
    "react-native-calendars": "^1.1314.0",
    "react-native-modal-datetime-picker": "^18.0.0",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.16.0",
    "react-native-uuid": "^2.0.4",
    "react-native-web": "^0.21.0",
    "zustand": "^5.0.13"
  },
  "devDependencies": {
    "@types/react": "~19.1.0",
    "concurrently": "^9.2.1",
    "electron": "^33.4.11",
    "electron-builder": "^25.1.8",
    "typescript": "~5.9.2",
    "wait-on": "^8.0.5"
  },
  "private": true
}
